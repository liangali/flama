{
  "common": {
    "debug": false,
    "use_cb": true,
    "cb-multi-thread": false,
    "new-multithread": true,
    "decode_mode": "hw",
    "input_video_path": "path/to/your/video.mp4",
    "output_dir": "output",
    "new_batch_mode": true,
    "vpp_downscaling": {
      "width": 224,
      "height": 224
    }
  },

  "frame_selector": {
    "policy": "frame",
    "frame_interval": 60,
    "window_seconds": 1.0,
    "max_per_window": 2,
    "min_frames_between": 0,
    "min_seconds_between": 0.0,
    "max_cached": 64,
    "remove_after_process": true,
    "force_keyframe": true,
    "enable_scene_cut": false,
    "min_frames_between_scene_cut": 0,
    "min_seconds_between_scene_cut": 0.0,
    "enable_cache": false
  },

  "batch": {
    "new_batch_mode": true,
    "batch_trigger": 10,
    "max_cache": 128,
    "decode_window": 0,
    "flush_partial": true,
    "cb_batch_size": 10,
    "max_frames_per_request": 128
  },

  "genai": {
    "model_path": "path/to/your/model",
    "device": "GPU",
    "scheduler": {
      "max_num_batched_tokens": 4096,
      "dynamic_split_fuse": false,
      "max_num_seqs": 64,
      "num_kv_blocks": 0,
      "cache_size": 0,
      "use_cache_eviction": false,
      "enable_prefix_caching": false,
      "use_sparse_attention": false
    }
  }
}
